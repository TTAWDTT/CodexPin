{
  "name": "codexpin",
  "version": "1.0.0",
  "description": "A lightweight always-on-top Codex progress widget that keeps users aware of task status while they switch to other work.",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node tests/state.test.js && node tests/hook.test.js && node tests/notify-setup.test.js",
    "lint": "echo \"No linter configured\"",
    "build": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TTAWDTT/CodexPin.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/TTAWDTT/CodexPin/issues"
  },
  "homepage": "https://github.com/TTAWDTT/CodexPin#readme",
  "devDependencies": {
    "@iarna/toml": "^3.0.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.codexpin.widget",
    "productName": "CodexPin",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5"
  }
}
