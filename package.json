{
  "name": "codexpin",
  "version": "1.0.0",
  "description": "A lightweight always-on-top Codex progress widget that keeps users aware of task status while they switch to other work.",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node tests/state.test.js && node tests/hook.test.js && node tests/notify-setup.test.js && node tests/codexpin-status.test.js && node tests/codexpin-cli.test.js && node tests/install-bootstrap.test.js && node tests/runtime-mode.test.js && node tests/codex-process-state.test.js && node tests/codex-rollout-live.test.js && node tests/status-feedback.test.js && node tests/window-geometry.test.js && node tests/build-config.test.js && node tests/icon-assets.test.js",
    "setup:hook": "node scripts/codexpin-cli.js setup",
    "uninstall:hook": "node scripts/codexpin-cli.js uninstall",
    "lint": "echo \"No linter configured\"",
    "build": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TTAWDTT/CodexPin.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/TTAWDTT/CodexPin/issues"
  },
  "homepage": "https://github.com/TTAWDTT/CodexPin#readme",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.codexpin.widget",
    "productName": "CodexPin",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "scripts/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon/codexpin.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon/codexpin.ico",
      "uninstallerIcon": "assets/icon/codexpin.ico",
      "installerHeaderIcon": "assets/icon/codexpin.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5"
  }
}
